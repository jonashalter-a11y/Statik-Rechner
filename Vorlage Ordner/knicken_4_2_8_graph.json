{
  "version": 1,
  "nodes": [
    {
      "id": "var_l",
      "type": "variable",
      "position": { "x": 40, "y": 40 },
      "data": {
        "kind": "variable",
        "name": "l",
        "label": "Stablänge",
        "unit": "mm",
        "default_value": "3000",
        "inputKind": "number",
        "description": "Länge des Druckstabes zwischen den Auflagern"
      }
    },
    {
      "id": "var_b",
      "type": "variable",
      "position": { "x": 40, "y": 180 },
      "data": {
        "kind": "variable",
        "name": "b",
        "label": "Breite",
        "unit": "mm",
        "default_value": "80",
        "inputKind": "number",
        "description": "Querschnittsbreite des Stabes"
      }
    },
    {
      "id": "var_h",
      "type": "variable",
      "position": { "x": 40, "y": 320 },
      "data": {
        "kind": "variable",
        "name": "h",
        "label": "Höhe",
        "unit": "mm",
        "default_value": "120",
        "inputKind": "number",
        "description": "Querschnittshöhe des Stabes"
      }
    },
    {
      "id": "var_N",
      "type": "variable",
      "position": { "x": 40, "y": 460 },
      "data": {
        "kind": "variable",
        "name": "N_d",
        "label": "Druckkraft (Bemessung)",
        "unit": "kN",
        "default_value": "50",
        "inputKind": "number",
        "description": "Bemessungswert der Druckkraft"
      }
    },
    {
      "id": "woodclass_fc",
      "type": "woodclass",
      "position": { "x": 40, "y": "600" },
      "data": {
        "kind": "woodclass",
        "label": "Holzeigenschaften",
        "properties": ["fc0d", "fc0k", "E005"],
        "description": "Druckfestigkeit und E-Modul aus Holzart"
      }
    },
    {
      "id": "dropdown_holzart",
      "type": "dropdown",
      "position": { "x": 280, "y": 620 },
      "data": {
        "kind": "dropdown",
        "label": "Holzart (für β_c)",
        "name": "wood_type",
        "mode": "custom",
        "options": [
          {
            "label": "Vollholz, keilgezinktes Vollholz, Balkenschichtholz",
            "value": "vollholz"
          },
          {
            "label": "Brettschichtholz",
            "value": "bsh"
          }
        ],
        "description": "Bestimmt den Hilfswert β_c nach SIA 265 4.2.8.3 (i-Button)"
      }
    },
    {
      "id": "calc_A",
      "type": "calc",
      "position": { "x": 520, "y": 240 },
      "data": {
        "kind": "calc",
        "name": "A",
        "label": "Querschnittsfläche",
        "unit": "mm²",
        "latex": "A = b \\cdot h",
        "expr": "b * h",
        "description": "Fläche des rechteckigen Querschnitts"
      }
    },
    {
      "id": "calc_i",
      "type": "calc",
      "position": { "x": 520, "y": 380 },
      "data": {
        "kind": "calc",
        "name": "i",
        "label": "Trägheitsradius",
        "unit": "mm",
        "latex": "i = \\frac{h}{\\sqrt{12}}",
        "expr": "h / Math.sqrt(12)",
        "description": "Trägheitsradius für Rechteck-Querschnitt (schwache Achse)"
      }
    },
    {
      "id": "calc_lambda",
      "type": "calc",
      "position": { "x": 520, "y": 520 },
      "data": {
        "kind": "calc",
        "name": "lambda",
        "label": "Schlankheitsgrad",
        "unit": "-",
        "latex": "\\lambda = \\frac{l}{i}",
        "expr": "l / i",
        "description": "Geometrischer Schlankheitsgrad (Längenverhältnis)"
      }
    },
    {
      "id": "calc_beta_c",
      "type": "cases",
      "position": { "x": 800, "y": 620 },
      "data": {
        "kind": "cases",
        "name": "beta_c",
        "label": "Hilfswert β_c",
        "unit": "-",
        "description": "SIA 265 4.2.8.3: abhängig von Holzart (i-Button)",
        "cases": [
          {
            "id": "case_vollholz",
            "cond_expr": "wood_type === 'vollholz'",
            "formula": "0.2",
            "label": "Vollholz"
          },
          {
            "id": "case_bsh",
            "cond_expr": "wood_type === 'bsh'",
            "formula": "0.1",
            "label": "BSH"
          }
        ]
      }
    },
    {
      "id": "calc_lambda_rel_factor",
      "type": "cases",
      "position": { "x": 800, "y": 750 },
      "data": {
        "kind": "cases",
        "name": "lambda_rel_factor",
        "label": "λ_rel Divisor",
        "unit": "-",
        "description": "SIA 265 4.2.8.4: 57 (Vollholz) oder 60 (BSH)",
        "cases": [
          {
            "id": "case_factor_vollholz",
            "cond_expr": "wood_type === 'vollholz'",
            "formula": "57",
            "label": "Vollholz"
          },
          {
            "id": "case_factor_bsh",
            "cond_expr": "wood_type === 'bsh'",
            "formula": "60",
            "label": "BSH"
          }
        ]
      }
    },
    {
      "id": "calc_lambda_rel",
      "type": "calc",
      "position": { "x": 1080, "y": 620 },
      "data": {
        "kind": "calc",
        "name": "lambda_rel",
        "label": "Relative Schlankheit",
        "unit": "-",
        "latex": "\\lambda_{rel} = \\frac{\\lambda}{f_c}",
        "expr": "lambda / lambda_rel_factor",
        "description": "SIA 265 4.2.8.4: λ / (57 für Vollholz, 60 für BSH)"
      }
    },
    {
      "id": "calc_k",
      "type": "calc",
      "position": { "x": 1080, "y": 750 },
      "data": {
        "kind": "calc",
        "name": "k",
        "label": "Hilfswert k",
        "unit": "-",
        "latex": "k = 0.5 \\cdot [1 + \\beta_c \\cdot (\\lambda_{rel} - 0.3) + \\lambda_{rel}^2]",
        "expr": "0.5 * (1 + beta_c * (lambda_rel - 0.3) + lambda_rel * lambda_rel)",
        "description": "SIA 265 4.2.8.2 Gleichung 31"
      }
    },
    {
      "id": "calc_kc",
      "type": "calc",
      "position": { "x": 1360, "y": 700 },
      "data": {
        "kind": "calc",
        "name": "k_c",
        "label": "Knickebeiwert",
        "unit": "-",
        "latex": "k_c = \\frac{1}{k + \\sqrt{k^2 - \\lambda_{rel}^2}}",
        "expr": "1 / (k + Math.sqrt(k * k - lambda_rel * lambda_rel))",
        "description": "SIA 265 4.2.8.2 Gleichung 30"
      }
    },
    {
      "id": "calc_sigma_c0d",
      "type": "calc",
      "position": { "x": 800, "y": 240 },
      "data": {
        "kind": "calc",
        "name": "sigma_c0d",
        "label": "Druckspannung",
        "unit": "N/mm²",
        "latex": "\\sigma_{c,0,d} = \\frac{N_d}{A}",
        "expr": "(N_d * 1000) / A",
        "description": "Bemessungswert der Druckspannung (N_d in kN → zu N umrechnen)"
      }
    },
    {
      "id": "calc_eta",
      "type": "calc",
      "position": { "x": 1640, "y": 700 },
      "data": {
        "kind": "calc",
        "name": "eta",
        "label": "Ausnutzungsgrad η",
        "unit": "-",
        "latex": "\\eta = \\frac{\\sigma_{c,0,d}}{k_c \\cdot f_{c,0,d}}",
        "expr": "sigma_c0d / (k_c * fc0d)",
        "description": "Nachweis erfüllt wenn η ≤ 1.0 (SIA 265 4.2.8.1 Gleichung 29)"
      }
    },
    {
      "id": "output",
      "type": "output",
      "position": { "x": 1900, "y": 700 },
      "data": {
        "kind": "output",
        "label": "Ergebnis Knicken",
        "blocks": ["calc_sigma_c0d", "calc_lambda_rel", "calc_kc", "calc_eta"]
      }
    }
  ],
